{
  "name": "opencode-goal-x",
  "version": "0.1.1",
  "description": "OpenCode plugin for persistent AI goals with draft confirmation, automatic continuations, todo sync, TUI status, and fail-closed audits.",
  "module": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./server": {
      "import": "./src/server.ts",
      "types": "./src/server.ts"
    },
    "./tui": {
      "import": "./src/tui.ts",
      "types": "./src/tui.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "bun test",
    "check:all": "bun run check && bun test",
    "smoke": "bun run check"
  },
  "engines": {
    "opencode": ">=1.17.11"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "goal-management",
    "auto-continue",
    "ai-agents",
    "workflow-automation",
    "audit",
    "tui-plugin",
    "todo-sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dogalyir/opencode-goal-x.git"
  },
  "bugs": {
    "url": "https://github.com/dogalyir/opencode-goal-x/issues"
  },
  "homepage": "https://github.com/dogalyir/opencode-goal-x#readme",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.11",
    "@opencode-ai/sdk": "^1.17.11",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
